# Copy this file to .env.geoclaw and put your real keys
NEWSAPI_KEY="PUT_REAL_NEWSAPI_KEY_HERE"
GUARDIAN_API_KEY="PUT_REAL_GUARDIAN_API_KEY_HERE"
ALPHAVANTAGE_KEY="PUT_REAL_ALPHAVANTAGE_KEY_HERE"
GEOCLAW_AUTO_SCHEDULE="false"
SCHEDULER_INTERVAL_MINUTES="30"
ALERT_EMAIL_FROM=your-email@gmail.com
ALERT_EMAIL_TO=recipient@example.com
ALERT_EMAIL_PASS=your-app-password
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/HOOK/URL
ALERT_DESKTOP=true

GEOCLAW_DB=geoclaw.db
# Shared secret for the _mutation_guard on every protected /api route and
# dashboard_api's Bearer middleware. When empty, mutation endpoints are
# localhost-only. Generate one with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
GEOCLAW_LOCAL_TOKEN=change-this-secret
# Production origin added to the SSE CORS allow-list on /api/events/stream.
# Exact scheme + host, no trailing slash. Leave unset in local dev.
# GEOCLAW_PRODUCTION_ORIGIN=https://app.example.com
# Optional: when set, POST /api/telegram/webhook requires header
#   X-Telegram-Bot-Api-Secret-Token: <value>
# Configure it at setWebhook time via the `secret_token` parameter so
# real Telegram deliveries include the header automatically.
# TELEGRAM_WEBHOOK_SECRET=generate-with-secrets.token_urlsafe
# Optional comma-separated Host-header allow-list. When set, requests
# whose Host header is not in the list get 400. Defense against HTTP
# Host header injection. localhost / 127.0.0.1 / testserver are always
# added automatically. Example:
#   GEOCLAW_TRUSTED_HOSTS=app.example.com,*.example.com
# GEOCLAW_TRUSTED_HOSTS=
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO
OPENAI_API_KEY=sk-your-key-here
GEOCLAW_LLM_MODEL=gpt-4o-mini
LLM_BUDGET_PER_HOUR=20
LLM_CALLS_PER_RUN=5
GEOCLAW_AUTO_SCHEDULE=false
AGENT_RUN_INTERVAL=30
ALERT_EMAIL_FROM=your-email@gmail.com
ALERT_EMAIL_TO=recipient@example.com
ALERT_EMAIL_PASS=your-app-password
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/HOOK
ALERT_DESKTOP=true
TELEGRAM_BOT_TOKEN=123456:ABCdefGHI...
TELEGRAM_CHAT_ID=your_chat_id
MAX_ARTICLES_PER_RUN=100
CONFIDENCE_FLOOR=0.15
CONFIDENCE_CEILING=0.93
